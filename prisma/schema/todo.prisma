model Todo {
  id         String    @id @default(cuid())
  title      String
  completed  Boolean   @default(false)
  dueDate    DateTime?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
